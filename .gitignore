# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Next.js build output ──────────────────────────────────────
.next/
out/
dist/
build/

# ── TypeScript incremental build cache ────────────────────────
*.tsbuildinfo

# ── Environment variables (never commit real secrets) ─────────
.env
.env.local
.env.*.local
.env.production

# ── Prisma generated client (regenerated via prisma generate) ─
# prisma/generated/   ← uncomment if you add a custom output dir

# ── Claude Code session data ──────────────────────────────────
.claude/

# ── OS / editor noise ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Vercel ────────────────────────────────────────────────────
.vercel
